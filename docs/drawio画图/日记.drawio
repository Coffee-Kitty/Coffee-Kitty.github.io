        <mxCell id="oz8Y0gxex3cJuwE7ILAa-15" value="数据源是&lt;a style=&quot;box-sizing: border-box; cursor: pointer; -webkit-user-drag: none; text-decoration-line: none; font-family: &amp;quot;Iosevka Curly&amp;quot;, &amp;quot;JetBrains Mono&amp;quot;, &amp;quot;Fira Code&amp;quot;, &amp;quot;Cascadia Code&amp;quot;, Menlo, &amp;quot;Ubuntu Mono&amp;quot;, Consolas, HYZhengYuan; font-size: 14px; orphans: 4; text-align: start; white-space: pre-wrap; background-color: rgb(255, 255, 255);&quot; href=&quot;https://github.com/microsoft/CodeBERT/tree/master/CodeReviewer&quot;&gt;CodeReviewer&lt;/a&gt;的，&lt;div&gt;最终测试集考虑自己github抓取最近新出的25年的项目的review&amp;nbsp;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
